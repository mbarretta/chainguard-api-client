{
  "name": "chainguard-api-client",
  "version": "0.2.0",
  "description": "Fast, lightweight, type-safe TypeScript client for the Chainguard API v2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "openapi-typescript spec/openapi.json -o src/generated/types.ts",
    "spec:refresh": "node scripts/refresh-spec.mjs && npm run generate",
    "spec:verify": "node scripts/verify-spec.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run spec:verify",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "chainguard",
    "api",
    "client",
    "typescript",
    "openapi"
  ]
}
